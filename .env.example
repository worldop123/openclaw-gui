# OpenClaw GUI 环境变量配置

# OpenClaw Gateway 配置
OPENCLAW_GATEWAY_HOST=localhost
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_AUTH_TOKEN=ef7adab7d41a68c9a33b050395e0edcc4b34e80edf65353c

# 后端服务配置
NODE_ENV=production
PORT=5000

# 前端配置
VITE_API_URL=http://localhost:5000
VITE_WS_URL=ws://localhost:5000

# Redis配置
REDIS_URL=redis://localhost:6379

# Docker配置
DOCKER_NETWORK=openclaw-network

# 开发模式配置
# 开发时取消注释以下行
# NODE_ENV=development
# VITE_API_URL=http://localhost:5000
# VITE_WS_URL=ws://localhost:5000