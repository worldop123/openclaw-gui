    maxExp: 12000,
    hp: 80,
    maxHp: 100,
    mp: 100,
    maxMp: 100,
    avatar: '🧙‍♂️',
    avatarColor: 'from-purple-400 to-pink-500',
    skills: ['React', 'TypeScript', 'Node.js', 'Python'],
    currentTask: '编写组件魔法',
    taskProgress: 82,
    lastActive: new Date(Date.now() - 30000),
    isAgent: true,
    equipment: ['法袍', '代码魔杖', 'API卷轴'],
    achievements: ['代码大师', 'Bug克星', '1000次提交']
  },
  {
    id: 'char-003',
    name: '飞书小管家',
    role: '日程游侠',
    class: 'ranger',
    status: 'working',
    level: 22,
    exp: 7200,
    maxExp: 9000,
    hp: 90,
    maxHp: 100,
    mp: 70,
    maxMp: 100,
    avatar: '🏹',
    avatarColor: 'from-green-400 to-emerald-500',
    skills: ['日历', '任务', '文档', '会议'],
    currentTask: '同步日程',
    taskProgress: 45,
    lastActive: new Date(Date.now() - 60000),
    isAgent: true,
    equipment: ['日程弓', '任务箭袋', '时间护符'],
    achievements: ['准时达人', '会议大师', '任务猎人']
  },
  {
    id: 'char-004',
    name: '记忆管理员',
    role: '知识守护者',
    class: 'healer',
    status: 'idle',
    level: 20,
    exp: 6500,
    maxExp: 8000,
    hp: 85,
