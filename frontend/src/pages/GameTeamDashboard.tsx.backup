    lastActive: new Date(Date.now() - 300000),
    isAgent: true,
    equipment: ['网络匕首', '隐身斗篷', '数据袋'],
    achievements: ['网络探险家', '信息猎人', '数据忍者']
  }
]

export default function GameTeamDashboard() {
  const [characters, setCharacters] = useState<GameCharacter[]>(initialCharacters)
  const [selectedCharacter, setSelectedCharacter] = useState<GameCharacter | null>(null)

  // 模拟实时更新
  useEffect(() => {
    const interval = setInterval(() => {
      setCharacters(prev => prev.map(char => {
        if (Math.random() > 0.7) {
          const newProgress = Math.min(100, char.taskProgress + Math.random() * 10)
          return {
            ...char,
            taskProgress: newProgress,
            lastActive: new Date()
          }
        }
        return char
      }))
    }, 3000)

    return () => clearInterval(interval)
  }, [])

  const formatTimeAgo = (date: Date): string => {
    const seconds = Math.floor((new Date().getTime() - date.getTime()) / 1000
    if (seconds < 60) return '刚刚'
    if (seconds < 3600) return Math.floor(seconds / 60) + '分钟前'
    return Math.floor(seconds / 3600) + '小时前'
  }

  const renderBars = (value: number, max: number, color: string) => {
    const percentage = (value / max) * 100
    return (
      <div className="flex items-center gap-2">
        <div className="flex-1 h-2.5 bg-slate-200 rounded-full overflow-hidden">
          <div
            className={'h-full rounded-full transition-all duration-500 ' + color}
            style={{ width: percentage + '%' }}
          />
        </div>
        <span className="text-xs text-slate-500 font-mono w-12">{value}/{max}</span>
      </div>
    )
  }

  return (
    <div className="space-y-6 p-6 bg-gradient-to-br from-slate-900 via-purple-900 to-slate-900 min-h-screen">
      {/* Header */}
      <div className="bg-gradient-to-r from-purple-600 via-pink-600 to-orange-600 rounded-2xl p-8 text-white relative overflow-hidden">
        <div className="relative z-10">
          <div className="flex items-center justify-between">
            <div>
              <div className="flex items-center gap-3 mb-2">
                <Trophy className="h-8 w-8" />
                <h1 className="text-4xl font-bold">OpenClaw 冒险队</h1>
              </div>
              <p className="text-purple-100 text-lg">管理你的AI英雄团队，一起冒险吧！</p>
            </div>
            <div className="flex items-center gap-6">
              <div className="text-center">
                <div className="text-3xl font-bold">{characters.length}</div>
                <div className="text-purple-200 text-sm">英雄</div>
              </div>
              <div className="text-center">
                <div className="text-3xl font-bold">
                  {characters.filter(c => c.status === 'working' || c.status === 'typing').length}
                </div>
                <div className="text-purple-200 text-sm">活跃中</div>
              </div>
              <div className="text-center">
                <div className="text-3xl font-bold">
                  {characters.reduce((sum, c) => sum + c.level, 0)}
                </div>
                <div className="text-purple-200 text-sm">总等级</div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div className="grid gap-6 lg:grid-cols-3">
        {/* 角色网格 */}
        <div className="lg:col-span-2 space-y-6">
          <div className="bg-slate-800/80 backdrop-blur rounded-xl border border-slate-700 overflow-hidden">
            <div className="border-b border-slate-700 p-6 bg-slate-900/50">
              <h3 className="font-bold text-xl flex items-center gap-3 text-white">
                <Users className="h-5 w-5 text-purple-400" />
                英雄队伍
              </h3>
            </div>
            <div className="p-6 grid gap-6 md:grid-cols-2">
              {characters.map(char => (
                <div
                  key={char.id}
                  onClick={() => setSelectedCharacter(char)}
                  className={'p-6 rounded-xl border-2 cursor-pointer transition-all ' + (
                    selectedCharacter?.id === char.id 
                      ? 'border-purple-500 shadow-xl shadow-purple-500/25' 
                      : 'border-slate-700 hover:border-slate-600 hover:shadow-lg'
                  ) + ' bg-slate-900/50 backdrop-blur'}
                >
                  {/* 角色头部 */}
                  <div className="flex items-start justify-between mb-4">
                    <div className="flex items-center gap-4">
                      <div className="relative">
                        <div className={'w-16 h-16 rounded-xl flex items-center justify-center text-3xl bg-gradient-to-br ' + char.avatarColor + ' shadow-lg'}>
                          {char.avatar}
                        </div>
                        <div className={'absolute -bottom-1 -right-1 w-5 h-5 rounded-full border-3 border-slate-900 ' + (
                          char.status === 'working' || char.status === 'typing' ? 'bg-green-500' :
                          char.status === 'sleeping' ? 'bg-slate-400' :
                          'bg-yellow-500'
                        )} />
                      </div>
                      <div>
                        <div className="flex items-center gap-2 mb-1">
                          <h4 className="font-bold text-lg text-white">{char.name}</h4>
                          {char.isAgent && (
                            <span className="px-2 py-0.5 text-xs rounded-full bg-purple-500 text-white">AI</span>
                          )}
                        </div>
                        <div className="flex items-center gap-2 mb-1">
                          <span className="text-slate-400 text-sm">Lv.{char.level}</span>
                        </div>
                      </div>
                    </div>
                    <div className="flex items-center gap-1">
                      <Star className="h-4 w-4 text-yellow-400" />
                      <span className="text-yellow-400 font-bold">{char.level}</span>
                    </div>
                  </div>

                  {/* 经验条 */}
                  <div className="mb-4">
                    <div className="flex items-center justify-between mb-1">
                      <span className="text-xs text-slate-400">经验</span>
                      <span className="text-xs text-purple-400">{char.exp}/{char.maxExp}</span>
                    </div>
                    {renderBars(char.exp, char.maxExp, 'bg-gradient-to-r from-purple-500 to-pink-500')}
                  </div>

                  {/* HP/MP 条 */}
                  <div className="space-y-2 mb-4">
                    <div>
                      <div className="flex items-center justify-between mb-1">
                        <span className="text-xs text-slate-400">HP</span>
                      </div>
                      {renderBars(char.hp, char.maxHp, 'bg-gradient-to-r from-red-500 to-rose-500')}
                    </div>
                    <div>
                      <div className="flex items-center justify-between mb-1">
                        <span className="text-xs text-slate-400">MP</span>
                      </div>
                      {renderBars(char.mp, char.maxMp, 'bg-gradient-to-r from-blue-500 to-cyan-500')}
                    </div>
                  </div>

                  {/* 当前任务 */}
                  {char.currentTask && (
                    <div className="mb-4 p-4 rounded-lg bg-slate-800/50 border border-slate-700">
                      <div className="text-sm text-slate-300 mb-2">{char.currentTask}</div>
                      <div className="h-2 rounded-full bg-slate-700 overflow-hidden">
                        <div
                          className={'h-full rounded-full bg-gradient-to-r ' + char.avatarColor + ' transition-all duration-500'}
                          style={{ width: char.taskProgress + '%' }}
                        />
                      </div>
                      <div className="flex justify-between text-xs text-slate-500 mt-1">
                        <span>{char.taskProgress.toFixed(0)}%</span>
                        <span>{formatTimeAgo(char.lastActive)}</span>
                      </div>
                    </div>
                  )}

                  {/* 技能标签 */}
                  <div className="flex flex-wrap gap-1.5 mb-4">
                    {char.skills.slice(0, 3).map((skill, idx) => (
                      <span
                        key={idx}
                        className="px-2 py-1 text-xs rounded-full bg-slate-700 text-slate-300"
                      >
                        {skill}
                      </span>
                    ))}
                  </div>

                  {/* 装备显示 */}
                  <div className="flex items-center justify-between pt-4 border-t border-slate-700">
                    <div className="flex items-center gap-1 text-xs text-slate-400">
                      <Shield className="h-3.5 w-3.5" />
                      {char.equipment.length} 装备
                    </div>
                    <div className="flex items-center gap-1 text-xs text-yellow-400">
                      <Trophy className="h-3.5 w-3.5" />
                      {char.achievements.length} 成就
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>

        {/* 选中角色详情 */}
        <div className="space-y-6">
          {selectedCharacter ? (
            <div className="bg-slate-800/80 backdrop-blur rounded-xl border border-slate-700 overflow-hidden">
              <div className="p-6 border-b border-slate-700 bg-slate-900/50">
                <div className="flex items-center gap-3 mb-2">
                  <div className={'w-20 h-20 rounded-xl flex items-center justify-center text-4xl bg-gradient-to-br ' + selectedCharacter.avatarColor + ' shadow-lg'}>
                    {selectedCharacter.avatar}
                  </div>
                  <div>
                    <h3 className="font-bold text-2xl text-white">{selectedCharacter.name}</h3>
                    <p className="text-slate-400">{selectedCharacter.role}</p>
                    <div className="flex items-center gap-2 mt-1">
                      <span className="text-yellow-400 font-bold">Lv.{selectedCharacter.level}</span>
                    </div>
                  </div>
                </div>
              </div>

              <div className="p-6 space-y-6">
                {/* 详细统计 */}
                <div className="space-y-4">
                  <h4 className="font-semibold text-white">属性</h4>
                  <div className="space-y-3">
                    <div>
                      <div className="flex items-center justify-between mb-1">
                        <span className="text-sm text-slate-400">HP</span>
                        <span className="text-sm text-slate-300 font-mono">{selectedCharacter.hp}/{selectedCharacter.maxHp}</span>
                      </div>
                      {renderBars(selectedCharacter.hp, selectedCharacter.maxHp, 'bg-gradient-to-r from-red-500 to-rose-500')}
                    </div>
                    <div>
                      <div className="flex items-center justify-between mb-1">
                        <span className="text-sm text-slate-400">MP</span>
                        <span className="text-sm text-slate-300 font-mono">{selectedCharacter.mp}/{selectedCharacter.maxMp}</span>
                      </div>
                      {renderBars(selectedCharacter.mp, selectedCharacter.maxMp, 'bg-gradient-to-r from-blue-500 to-cyan-500')}
                    </div>
                    <div>
                      <div className="flex items-center justify-between mb-1">
                        <span className="text-sm text-slate-400">EXP</span>
                        <span className="text-sm text-slate-300 font-mono">{selectedCharacter.exp}/{selectedCharacter.maxExp}</span>
                      </div>
                      {renderBars(selectedCharacter.exp, selectedCharacter.maxExp, 'bg-gradient-to-r from-yellow-500 to-orange-500')}
                    </div>
                  </div>
                </div>
              </div>
            </div>
          ) : (
            <div className="bg-slate-800/80 backdrop-blur rounded-xl border border-slate-700 p-12 text-center">
              <Users className="h-16 w-16 text-slate-600 mx-auto mb-4" />
              <h3 className="text-lg font-medium text-slate-400 mb-2">选择一个英雄</h3>
              <p className="text-slate-500">从左侧选择一个英雄查看详情</p>
            </div>
          )}
        </div>
      </div>
    </div>
  )
}
