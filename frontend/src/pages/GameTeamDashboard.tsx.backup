    mp: 90,
    maxMp: 100,
    avatar: '🧠',
    avatarColor: 'from-blue-400 to-cyan-500',
    skills: ['记忆存储', '信息检索', '知识图谱'],
    currentTask: null,
    taskProgress: 0,
    lastActive: new Date(Date.now() - 120000),
    isAgent: true,
    equipment: ['记忆水晶', '检索杖', '知识之书'],
    achievements: ['记忆大师', '检索专家', '知识守护者']
  },
  {
    id: 'char-005',
    name: '文件管理员',
    role: '仓库守卫',
    class: 'tank',
    status: 'working',
    level: 18,
    exp: 5800,
    maxExp: 7000,
    hp: 100,
    maxHp: 100,
    mp: 60,
    maxMp: 100,
    avatar: '🛡️',
    avatarColor: 'from-slate-400 to-gray-500',
    skills: ['文件操作', '目录管理', '备份', '归档'],
    currentTask: '整理文件',
    taskProgress: 35,
    lastActive: new Date(Date.now() - 180000),
    isAgent: true,
