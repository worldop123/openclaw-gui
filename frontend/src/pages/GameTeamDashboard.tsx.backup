import { useEffect, useState } from 'react'
import { 
  Trophy, 
  Zap, 
  Star, 
  Heart,
  Coffee,
  Code,
  Cpu,
  Terminal,
  Search,
  BookOpen,
  Shield,
  MessageSquare,
  Workflow,
  Users,
  Settings
} from 'lucide-react'

type CharacterStatus = 'idle' | 'working' | 'typing' | 'thinking' | 'sleeping' | 'celebrating'

interface GameCharacter {
  id: string
  name: string
  role: string
  class: 'warrior' | 'mage' | 'rogue' | 'healer' | 'tank' | 'ranger'
  status: CharacterStatus
  level: number
  exp: number
  maxExp: number
  hp: number
  maxHp: number
  mp: number
  maxMp: number
  avatar: string
  avatarColor: string
  skills: string[]
  currentTask: string | null
  taskProgress: number
  lastActive: Date
  isAgent: boolean
  equipment: string[]
  achievements: string[]
}

const initialCharacters: GameCharacter[] = [
  {
    id: 'char-001',
    name: '小明',
    role: '领袖',
    class: 'warrior',
    status: 'working',
    level: 25,
    exp: 8500,
    maxExp: 10000,
    hp: 100,
    maxHp: 100,
    mp: 80,
    maxMp: 100,
    avatar: '👨‍💼',
    avatarColor: 'from-yellow-400 to-orange-500',
    skills: ['战术指挥', '团队协调', '决策制定'],
    currentTask: '协调团队任务',
    taskProgress: 65,
    lastActive: new Date(),
    isAgent: false,
    equipment: ['领导者头盔', '指挥剑', '战术地图'],
    achievements: ['第一滴血', '团队协作', '完美指挥']
  },
  {
    id: 'char-002',
    name: '代码小助手',
    role: '代码法师',
    class: 'mage',
    status: 'typing',
    level: 30,
